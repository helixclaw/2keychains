{
  "name": "2keychains",
  "version": "0.1.0",
  "description": "A local secret broker with controlled access, approval flows, and ephemeral injection",
  "type": "module",
  "bin": {
    "2kc": "./dist/cli/index.js"
  },
  "scripts": {
    "tsx": "tsx",
    "build": "tsup",
    "dev": "tsup --watch",
    "compile": "tsc --noEmit",
    "lint": "eslint --fix . && prettier --write .",
    "lint:no-fix": "eslint . && prettier --check .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:no-coverage": "vitest run",
    "prepare": "lefthook install"
  },
  "keywords": [
    "secrets",
    "keychain",
    "1password",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "fastify": "^5.7.4",
    "fastify-plugin": "^5.1.0",
    "jose": "^6.1.3",
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "zod-validation-error": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/node": "^22.13.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.20.0",
    "lefthook": "^2.1.1",
    "prettier": "^3.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.24.0",
    "vitest": "^3.0.0"
  }
}
